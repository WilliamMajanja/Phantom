# PHANTOM - AI-Native Tactical Audio Workstation
# Environment Configuration

# Local Ollama model used by Ghost Bridge before cloud fallback
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3:8b-instruct-q4_K_M

# Google Gemini API Key (optional cloud fallback for AI features)
GEMINI_API_KEY=

# Application URL (Used for OAuth and deep linking)
APP_URL=http://localhost:3000

# HTTP bind settings for Raspberry Pi OS Trixie / systemd deployments
HOST=0.0.0.0
PORT=3000

# Node Environment
NODE_ENV=development
