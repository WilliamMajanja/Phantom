# PHANTOM - AI-Native Tactical Audio Workstation
# Environment Configuration

# Local Ollama model used by Ghost Bridge
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3:8b-instruct-q4_K_M

# Application URL (Used for OAuth and deep linking)
APP_URL=http://localhost:3000
PHANTOM_URL=http://localhost:3000

# Minima node used for Raspberry Pi application readiness checks
MINIMA_BASE_URL=http://localhost:9001

# HTTP bind settings for Raspberry Pi OS Trixie / systemd deployments
HOST=0.0.0.0
PORT=3000
JSON_BODY_LIMIT=64kb
GHOST_SUMMON_RATE_LIMIT=10
SYSTEM_STATUS_RATE_LIMIT=30
STATIC_RATE_LIMIT=120

# Node Environment
NODE_ENV=development
