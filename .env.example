# PHANTOM - AI-Native Tactical Audio Workstation
# Environment Configuration

# Google Gemini API Key (Required for AI features)
GEMINI_API_KEY=

# Application URL (Used for OAuth and deep linking)
APP_URL=http://localhost:3000

# HTTP bind settings for Raspberry Pi OS Trixie / systemd deployments
HOST=0.0.0.0
PORT=3000

# Node Environment
NODE_ENV=development
